        "options": {}
      },
      "id": "sheets-read-sager",
      "name": "Læs Sager fra Sheets",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [220, 0],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "GOOGLE_CREDENTIAL_ID",
          "name": "Google Sheets"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Filtrér baseret på query-params\nconst query = $('Webhook: Hent Sager').first().json.query || {};\nlet sager = $input.all().map(i => i.json);\n\nif (query.udvalg) {\n  sager = sager.filter(s => s.udvalg && s.udvalg.toLowerCase().includes(query.udvalg.toLowerCase()));\n}\nif (query.kategori) {\n  sager = sager.filter(s => s.kategori === query.kategori);\n}\nif (query.min_relevans) {\n  sager = sager.filter(s => parseInt(s.relevans_score) >= parseInt(query.min_relevans));\n}\nif (query.status) {\n  sager = sager.filter(s => s.status === query.status);\n}\n\n// Sortér: højest relevans først, derefter nyeste dato\nsager.sort((a, b) => {\n  const scoreA = parseInt(a.relevans_score) || 0;\n  const scoreB = parseInt(b.relevans_score) || 0;\n  if (scoreB !== scoreA) return scoreB - scoreA;\n  return (b.møde_dato || '').localeCompare(a.møde_dato || '');\n});\n\nreturn [{ json: { sager, total: sager.length } }];"
      },
      "id": "filter-sager",
      "name": "Filtrér & Sortér",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 0]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify($json) }}",
        "options": {
          "responseHeaders": {
            "entries": [
              {
                "name": "Access-Control-Allow-Origin",
                "value": "*"
              }
            ]
          }
        }
      },
      "id": "respond-sager",
      "name": "Svar: Sager",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [660, 0]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "checkin",
        "responseMode": "responseNode",
        "options": {
          "allowedOrigins": "*"
        }
      },
      "id": "webhook-checkin",
      "name": "Webhook: Check-in",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 300],
      "webhookId": "checkin"
    },
    {
      "parameters": {
        "jsCode": "// Hent check-in data fra request body\nconst body = $input.first().json.body;\nconst sagId = body.sag_id;\nconst input = body.vores_input;\nconst tjekketIndAf = body.tjekket_ind_af || 'ukendt';\n\nif (!sagId || !input) {\n  return [{ json: { error: 'Mangler sag_id eller vores_input', status: 400 } }];\n}\n\nreturn [{\n  json: {\n    sag_id: sagId,\n    vores_input: input,\n    tjekket_ind_af: tjekketIndAf,\n    tjekket_ind_dato: new Date().toISOString()\n  }\n}];"
      },
      "id": "parse-checkin",
      "name": "Parse Check-in",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 300]
    },
    {
      "parameters": {
        "operation": "read",
        "documentId": {
          "__rl": true,
          "mode": "id",
          "value": "1vu5K3yWkIBlD8cJmo-1gOKXkCuP864Svp2OwWqin9oU"
        },
        "sheetName": {
          "__rl": true,
          "mode": "name",
          "value": "Sager"
        },
        "options": {}
      },
      "id": "sheets-read-for-update",
      "name": "Læs Sager for Opdatering",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [440, 300],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "GOOGLE_CREDENTIAL_ID",
          "name": "Google Sheets"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Find den rigtige række og opdatér\nconst checkin = $('Parse Check-in').first().json;\nconst allRows = $input.all().map(i => i.json);\n\nconst rowIndex = allRows.findIndex(r => r.id === checkin.sag_id);\nif (rowIndex === -1) {\n  return [{ json: { error: 'Sag ikke fundet: ' + checkin.sag_id, status: 404 } }];\n}\n\n// Returner data til opdatering\nreturn [{\n  json: {\n    row_number: rowIndex + 2, // +2 for header-række og 0-indexering\n    sag_id: checkin.sag_id,\n    vores_input: checkin.vores_input,\n    tjekket_ind_af: checkin.tjekket_ind_af,\n    tjekket_ind_dato: checkin.tjekket_ind_dato,\n    status: 'afklar'\n  }\n}];"
      },
      "id": "find-row",
      "name": "Find Række",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 300]
    },
    {
      "parameters": {
        "operation": "update",
        "documentId": {
          "__rl": true,
          "mode": "id",
          "value": "1vu5K3yWkIBlD8cJmo-1gOKXkCuP864Svp2OwWqin9oU"
        },
        "sheetName": {
          "__rl": true,
          "mode": "name",
          "value": "Sager"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "id": "={{ $json.sag_id }}",
            "vores_input": "={{ $json.vores_input }}",
            "tjekket_ind_af": "={{ $json.tjekket_ind_af }}",
            "tjekket_ind_dato": "={{ $json.tjekket_ind_dato }}",
            "status": "={{ $json.status }}"
          }
        },
        "options": {
          "cellFormat": "USER_ENTERED"
        }
      },
